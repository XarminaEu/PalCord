# Discord Bot
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_bot_client_id
DISCORD_GUILD_ID=your_guild_id_for_dev_registration

# Discord Bot Invite Button auf der Startseite (true/false)
DISCORD_INVITE_ENABLED=false

# PayPal Spenden Button auf der Startseite (true/false)
PAYPAL_ENABLED=false

# PayPal Spenden Link (volle PayPal.Me URL oder beliebiger Link)
PAYPAL_URL=https://paypal.me/your_username

# Discord OAuth (for Web Dashboard)
DISCORD_CLIENT_SECRET=your_discord_oauth_client_secret
DISCORD_CALLBACK_URL=http://your-domain:5996/auth/discord/callback

# App
APP_PORT=5996
APP_URL=http://your-domain:5996
SESSION_SECRET=change_this_to_a_random_long_string

# Database
DB_PATH=./data/palcord.db

# Global Admin
GLOBAL_ADMIN_ID=your_discord_user_id

# Logging
LOG_LEVEL=info

# Imprint / Legal Notice
IMPRINT_NAME=Robin Oliver Lucas
IMPRINT_ADDRESS=Schwarzbach 148
IMPRINT_CITY=42277 Wuppertal
IMPRINT_COUNTRY=Deutschland
IMPRINT_EMAIL=robin@rl-dev.de
